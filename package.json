{
  "name": "@imageat/mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for ImageAT — generate images, generate video, and run image-edit tools from any MCP client.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://imageat.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imageat/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/imageat/mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "imageat",
    "ai",
    "image-generation",
    "video-generation",
    "claude"
  ],
  "bin": {
    "imageat-mcp": "dist/index.js",
    "imageat-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
